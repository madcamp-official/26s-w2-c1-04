# 복사해서 쓴다:  cp backend/.env.example backend/.env
# .env 는 .gitignore 에 있다. 보안이 비목표라 시크릿 관리는 하지 않는다 (SPEC 1.2절).

DATABASE_URL=mysql+asyncmy://memory:pager@127.0.0.1:3306/memory_pager?charset=utf8mb4

MEDIA_ROOT=./media
MEDIA_URL_PREFIX=/media

# GPU 서버가 준비되기 전까지는 false. 스텁이 그럴듯한 값을 돌려준다.
# true 로 바꾸면 아래 두 URL 로 실제 추론을 부른다.
GPU_ENABLED=false
GPU_LLM_URL=http://10.0.0.42:8100
GPU_SD_URL=http://10.0.0.42:8200
LLM_MODEL=LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct-AWQ
GPU_TIMEOUT_SECONDS=120

EPHEMERAL_TTL_SECONDS=5

# FCM_CREDENTIALS_PATH=./secrets/firebase-admin.json

CORS_ORIGINS=*
